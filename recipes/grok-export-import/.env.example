# PostgreSQL connection string (from your Open Brain setup)
DATABASE_URL=postgresql://ob1:password@localhost:5432/ob1

# LiteLLM base URL (default: http://localhost:4000/v1)
LITELLM_BASE_URL=http://localhost:4000/v1

# LiteLLM API key (from your Open Brain setup)
LITELLM_API_KEY=your-litellm-api-key

# Optional: override the embedding model (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small
