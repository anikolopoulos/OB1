# Open Brain Email History Import
# Copy this file to .env and fill in your values.
# Then: export $(cat .env | xargs)

# PostgreSQL connection string (from your Open Brain Docker setup)
DATABASE_URL=postgresql://ob1:password@localhost:5432/ob1

# LiteLLM (for embedding generation and metadata extraction)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=your-litellm-api-key

# Model names — adjust to match what you have configured in LiteLLM
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
