# PostgreSQL
POSTGRES_USER=ob1
POSTGRES_PASSWORD=          # REQUIRED: generate with `openssl rand -hex 32`
POSTGRES_DB=ob1

# LiteLLM
LITELLM_BASE_URL=https://litellm.leadetic.com/v1
LITELLM_API_KEY=            # REQUIRED: your LiteLLM API key

# Models (optional overrides)
EMBEDDING_MODEL=text-embedding-3-small
METADATA_MODEL=gpt-4o-mini

# Admin API
ADMIN_API_KEY=              # REQUIRED: generate with `openssl rand -hex 32`

# Slack (optional — only if using Slack capture)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Domain (for Caddy TLS — set to your actual domain)
DOMAIN=brain.yourdomain.com
